<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Message</title>
  </head>
  <body>
    <h1>Message Details:</h1>
    <div>
      <h3>Name: <%= message.username %></h3>
      <p>Text: <%= message.text %></p>
      <small>Date: <%= message.date_added.toLocaleString() %></small>
    </div>
    <hr />
    <a href="/">Back to Message Board</a>
  </body>
</html>
