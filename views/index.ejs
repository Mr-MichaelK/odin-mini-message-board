<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>
    <a href="/new">Add new messages</a>
    <hr>

    <ul>
        <% messages.forEach((message) => { %>
            <li>
                <div>
                    <h3><%= message.username %></h3>
                    <p><%= message.text %></p>
                    <small><%= message.date_added.toLocaleString() %></small>
                    <br>
                    <a href=<%= `/message/${message.id}` %>>Open</a>
                </div>
            </li>
        <% }); %>
    </ul>
  </body>
</html>
